# ═══════════════════════════════════════════════════════════════
# Morpex v1.8 — 环境变量配置模板
#
# 使用方式:
#   cp .env.example .env
#   # 编辑 .env 填入实际值
#   # 系统启动时自动加载
#
# 注意: .env 文件包含敏感信息，不要提交到版本控制！
# ═══════════════════════════════════════════════════════════════

# ── AI 大模型 ─────────────────────────────────────────
# 必需！AI 对话功能依赖此 Key（DeepSeek 或 OpenAI 兼容 API）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 可选：指定 LLM 模型（默认 deepseek-chat）
# LLM_MODEL=deepseek-chat

# 可选：自定义 API 基址（兼容 OpenAI 格式）
# OPENAI_BASE_URL=https://api.deepseek.com

# ── 服务端口 ──────────────────────────────────────────
# 后端 API 端口（默认 8080）
# PORT=8080

# 绑定地址（默认 0.0.0.0，生产环境勿改）
# HOST=0.0.0.0

# ── Embedding 服务 ────────────────────────────────────
# Python BGE-M3 嵌入服务地址
# EMBEDDING_URL=http://localhost:3100/mcp

# 跳过 Embedding 服务（设为 1 则使用内存降级模式）
# SKIP_EMBEDDING=0

# ── 运行模式 ──────────────────────────────────────────
# production / development（影响日志格式和启动检查）
# NODE_ENV=production

# ── 配置路径 ──────────────────────────────────────────
# 自定义配置文件路径（默认自动查找 config.json）
# CONFIG_PATH=./production.config.json

# ── 前端地址（CORS） ──────────────────────────────────
# 前端部署地址（用于 CORS 白名单）
# FRONTEND_URL=https://morpex.your-domain.com

# ── 日志级别 ──────────────────────────────────────────
# debug / info / warn / error
# LOG_LEVEL=info
