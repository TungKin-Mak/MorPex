{
  "name": "morpex",
  "version": "11.0.0",
  "private": true,
  "type": "module",
  "description": "MorPex v11 — Adaptive Workflow Operating System (Backend)",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "══════════ 启动 (PM2) ══════════": "",
    "start": "pm2 start configs/pm2-ecosystem.config.cjs",
    "start:status": "pm2 status",
    "stop": "pm2 stop all",
    "restart": "pm2 restart all",
    "logs": "pm2 logs",
    "delete": "pm2 delete all",
    "══════════ 开发 (tsx 直接启动) ══════════": "",
    "dev": "npx tsx scripts/start.ts",
    "dev:status": "npx tsx scripts/start.ts --status",
    "dev:stop": "npx tsx scripts/start.ts stop",
    "══════════ v11 Workflow CLI ══════════": "",
    "wf:create": "npx tsx scripts/workflow-cli.ts create",
    "wf:install": "npx tsx scripts/workflow-cli.ts install",
    "wf:run": "npx tsx scripts/workflow-cli.ts run",
    "wf:list": "npx tsx scripts/workflow-cli.ts list",
    "wf:optimize": "npx tsx scripts/workflow-cli.ts optimize",
    "wf:versions": "npx tsx scripts/workflow-cli.ts versions",
    "wf:rollback": "npx tsx scripts/workflow-cli.ts rollback",
    "wf:status": "npx tsx scripts/workflow-cli.ts status",
    "wf:metrics": "npx tsx scripts/workflow-cli.ts metrics",
    "══════════ 测试 ══════════": "",
    "test": "node scripts/production-check.cjs",
    "test:all": "npx tsx scripts/run-all-tests.ts",
    "test:e2e": "npx tsx packages/core/e2e-test.ts",
    "test:api": "npx vitest run packages/core/src/extensions/planning/__tests__/",
    "test:system": "npx tsx scripts/run-all-tests.ts",
    "test:production": "npx tsx scripts/run-all-production-tests.ts",
    "test:k6": "bash scripts/run-k6-test.sh --smoke",
    "══════════ 后端 ══════════": "",
    "studio:server": "npx tsx packages/studio/server/index.ts",
    "══════════ 边界检查 ══════════": "",
    "check:boundaries": "bash scripts/check-boundaries.sh",
    "check:deps": "npx dependency-cruiser packages/ --config .dependency-cruiser.js",
    "check:versions": "grep -E '@earendil-works/pi-' package.json",
    "══════════ 核心 ══════════": "",
    "core:typecheck": "npx tsc --noEmit -p tsconfig.json",
    "══════════ 企业级 ══════════": "",
    "prod:docker": "cd configs && docker-compose up -d --build",
    "prod:docker:stop": "cd configs && docker-compose down",
    "══════════ 工具 ══════════": "",
    "embedding:start": "python tools-python/embedding-server.py --model-path data/models/bge-m3 --mode http --port 3100",
    "clean:all": "rm -rf data/mirror data/sessions/*.jsonl",
    "reset": "rm -rf data/zvec data/sessions/logs/*.log",
    "══════════ 依赖边界检查 ══════════": "",
    "depcheck": "npx dependency-cruiser packages/ --config .dependency-cruiser.json --output-type err-long || echo '⚠️ Dependency violations — see output above'",
    "depcheck:core": "npx dependency-cruiser packages/core/src --include-only '^packages/core' --output-type err-long",
    "verify:upgrade": "npm run core:typecheck && npm run depcheck && npm run test:system"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.81.1",
    "@earendil-works/pi-ai": "^0.81.1",
    "@earendil-works/pi-coding-agent": "^0.81.1",
    "@playwright/test": "^1.61.1",
    "@zvec/zvec": "^0.5.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "lru-cache": "^11.5.2",
    "pm2": "^7.0.3",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^20.19.43",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "brace-expansion": "5.0.7",
    "protobufjs@7.6.4": "7.6.5",
    "@earendil-works/pi-coding-agent": {
      "protobufjs": "7.6.5"
    }
  }
}
